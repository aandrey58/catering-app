# Скопируйте этот файл в `.env` в корне проекта.
# Docker Compose автоматически читает переменные из `.env`.

# Обязательно: секрет для подписи JWT.
# В продакшене используйте длинную случайную строку.
JWT_SECRET=change-me-to-a-long-random-secret

# Срок жизни access token в днях.
JWT_EXPIRE_DAYS=30

# Опционально: стартовый администратор, если БД пустая.
# SEED_ADMIN_LOGIN=admin
# SEED_ADMIN_PASSWORD=your-password
# SEED_ADMIN_NOTE=Admin

# Импорт данных из Google Sheets -> SQLite при старте контейнера backend.
SPREADSHEET_ID=your-spreadsheet-id-here
SERVICE_ACCOUNT_PATH=./backend/service_account.json

# Опционально: ручной запуск импорта без рестарта.
# Запрос: POST /api/sync_from_sheets с заголовком X-Sheets-Sync-Token.
# SHEETS_SYNC_TOKEN=choose-a-long-random-string

# Порт публикации nginx + frontend (API доступен по /api/...).
WEB_PORT=8080
