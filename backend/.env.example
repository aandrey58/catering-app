# Copy to .env and adjust. Never commit .env.

# Required in production: long random string for signing JWTs
JWT_SECRET=change-me-to-a-long-random-secret

# Access token lifetime (default 30)
JWT_EXPIRE_DAYS=30

# SQLite file under backend/ (path after ./ is relative to backend directory)
DATABASE_URL=sqlite:///./data/catering.db

# --- Google Sheets -> SQLite (at startup and via POST /sync_from_sheets) ---
# Put service_account.json in backend/ and either:
#   SPREADSHEET_ID=<id>   or   a one-line id in backend/table_id
# SPREADSHEET_ID=
# Optional: manual re-import without restart (requires header X-Sheets-Sync-Token)
# SHEETS_SYNC_TOKEN=choose-a-long-random-string

# Optional: create this user on startup ONLY if DB still has no users after Sheets import
# SEED_ADMIN_LOGIN=admin
# SEED_ADMIN_PASSWORD=your-password
# SEED_ADMIN_NOTE=Admin
